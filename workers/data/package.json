{
  "name": "@deeprecall/worker-data",
  "version": "0.0.1",
  "license": "Apache-2.0",
  "private": true,
  "exports": {
    ".": "./src/index.ts"
  },
  "scripts": {
    "dev": "wrangler dev --env dev",
    "build": "wrangler deploy --env dev --dry-run --outdir dist",
    "deploy:dev": "wrangler deploy --env dev",
    "deploy:prod": "wrangler deploy --env production",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "lint": "eslint src test",
    "cf-typegen": "wrangler types --env dev",
    "db:migrate:dev": "wrangler d1 migrations apply DB_default --env dev --remote",
    "db:migrate:prod": "wrangler d1 migrations apply DB_default --env production --remote",
    "db:migrate:local": "wrangler d1 migrations apply DB_default --local"
  },
  "dependencies": {
    "@deeprecall/types": "workspace:*",
    "@deeprecall/db": "workspace:*",
    "@deeprecall/vectorize": "workspace:*"
  },
  "devDependencies": {
    "@cloudflare/vitest-pool-workers": "^0.18.5",
    "@types/node": "^25.6.0",
    "typescript": "^5.5.2",
    "vitest": "~4.1.0",
    "wrangler": "^4.92.0"
  }
}
