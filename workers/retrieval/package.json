  },
  "devDependencies": {
    "@cloudflare/vitest-pool-workers": "^0.18.5",
    "@deeprecall/worker-data": "workspace:^",
    "@types/node": "^25.6.0",
    "typescript": "^5.5.2",
    "vitest": "~4.1.0",
    "wrangler": "^4.92.0"
  }
