{
  "$schema": "https://turborepo.org/schema.json",
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "outputs": ["dist/**"]
    },
    "typecheck": {
      "dependsOn": ["^build"]
    },
    "test": {
      "dependsOn": ["build"]
    },
    "lint": {},
    "deploy:dev": {
      "dependsOn": ["build"]
    },
    "deploy:prod": {
      "dependsOn": ["build"]
    }
  }
}
