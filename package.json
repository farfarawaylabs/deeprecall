{
  "name": "deeprecall",
  "license": "Apache-2.0",
  "private": true,
  "packageManager": "pnpm@10.8.1",
  "scripts": {
    "build": "turbo build",
    "test": "turbo test",
    "typecheck": "turbo typecheck",
    "lint": "turbo lint",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "dev": "pnpx wrangler dev --env dev -c workers/memory-api/wrangler.jsonc -c workers/ingestion/wrangler.jsonc -c workers/retrieval/wrangler.jsonc",
    "dev:memory-api": "pnpm --filter @deeprecall/worker-memory-api run dev",
    "dev:ingestion": "pnpm --filter @deeprecall/worker-ingestion run dev",
    "dev:retrieval": "pnpm --filter @deeprecall/worker-retrieval run dev",
    "dev:consolidation": "pnpm --filter @deeprecall/worker-consolidation run dev",
    "dev:management": "pnpm --filter @deeprecall/worker-management run dev",
    "db:migrate:local": "pnpm --filter @deeprecall/worker-data run db:migrate:local",
    "db:migrate:dev": "pnpm --filter @deeprecall/worker-data run db:migrate:dev",
    "db:migrate:prod": "pnpm --filter @deeprecall/worker-data run db:migrate:prod",
    "setup-product": "bash scripts/setup-product-db.sh",
    "deploy:dev": "pnpm deploy:dev:data && pnpm deploy:dev:retrieval && pnpm deploy:dev:ingestion && pnpm deploy:dev:memory-api && pnpm deploy:dev:consolidation && pnpm deploy:dev:management",
    "deploy:prod": "pnpm deploy:prod:data && pnpm deploy:prod:retrieval && pnpm deploy:prod:ingestion && pnpm deploy:prod:memory-api && pnpm deploy:prod:consolidation && pnpm deploy:prod:management",
    "deploy:dev:data": "pnpm --filter @deeprecall/worker-data run deploy:dev",
    "deploy:dev:retrieval": "pnpm --filter @deeprecall/worker-retrieval run deploy:dev",
    "deploy:dev:ingestion": "pnpm --filter @deeprecall/worker-ingestion run deploy:dev",
    "deploy:dev:memory-api": "pnpm --filter @deeprecall/worker-memory-api run deploy:dev",
    "deploy:dev:consolidation": "pnpm --filter @deeprecall/worker-consolidation run deploy:dev",
    "deploy:dev:management": "pnpm --filter @deeprecall/worker-management run deploy:dev",
    "deploy:prod:data": "pnpm --filter @deeprecall/worker-data run deploy:prod",
    "deploy:prod:retrieval": "pnpm --filter @deeprecall/worker-retrieval run deploy:prod",
    "deploy:prod:ingestion": "pnpm --filter @deeprecall/worker-ingestion run deploy:prod",
    "deploy:prod:memory-api": "pnpm --filter @deeprecall/worker-memory-api run deploy:prod",
    "deploy:prod:consolidation": "pnpm --filter @deeprecall/worker-consolidation run deploy:prod",
    "deploy:prod:management": "pnpm --filter @deeprecall/worker-management run deploy:prod"
  },
  "devDependencies": {
    "turbo": "^2",
    "typescript": "^5.8",
    "prettier": "^3",
    "eslint": "^9",
    "@eslint/js": "^9",
    "typescript-eslint": "^8",
    "eslint-config-prettier": "^10"
  }
}
